{
  "name": "open-workflow-doctor",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:ai:manual": "node scripts/manual-ai-patch-smoke.mjs",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b && npm run typecheck -w apps/web",
    "lint": "eslint .",
    "build": "tsc -b && npm run build -w apps/web"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.17.6",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
